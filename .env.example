SONARQUBE_ORG=...
SONARQUBE_TOKEN=...
CONTEXT7_API_KEY=...
TAVILY_API_KEY=...

# --- EZVIZ cloud diagnostics (scripts/ezviz_stream_probe.py, ezviz_list_cameras.py) ---
# 2FA MUST be disabled on this account (spec §7.1).
# Per-camera selection is a CLI flag (--serial), not an env var.
EZVIZ_EMAIL=you@example.com
EZVIZ_PASSWORD=your-ezviz-password
EZVIZ_REGION=Europe
# Image-Encryption password (the 6-letter verification code on the camera label).
# Needed only for cameras with Image Encryption ON; one shared code covers all of
# them here. Overridable per run with --verify-code.
EZVIZ_VERIFY_CODE=ABCDEF
